
# Firebase Public Config (for client-side)
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="1:your-sender-id:web:your-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-..."

# Firebase Admin SDK (for server-side)
# This is a JSON object, so it must be enclosed in quotes.
FIREBASE_ADMIN_SERVICE_ACCOUNT_KEY='{"type":"service_account",...}'

# Genkit/Gemini API Key
GEMINI_API_KEY="AIza..."

# Meta WhatsApp Business (WABA) — template messages only
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:9003"
META_WHATSAPP_DEFAULT_LOCALE="en_US"
# merchant_welcome body vars: default sends name + agreement URL (set false if template has only {{1}})
# META_WHATSAPP_WELCOME_INCLUDE_URL="false"
# Optional: override onboarding-complete template name / body var count
# META_WHATSAPP_ONBOARDING_COMPLETE_TEMPLATE="merchant_onboarding_complete"
# META_WHATSAPP_ONBOARDING_COMPLETE_INCLUDE_URL="false"
